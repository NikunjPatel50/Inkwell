# InsForge client config — copy to `.env.local` for local dev
NEXT_PUBLIC_INSFORGE_URL=https://your-appkey.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_anon_key_here

# Optional client-side GROQ fallback (prefer server-side GROQ_API_KEY on InsForge)
# NEXT_PUBLIC_GROQ_API_KEY=gsk_your_key_here

# Get values with:
# npx @insforge/cli current
# npx @insforge/cli secrets get ANON_KEY

# GROQ_API_KEY is set server-side via:
# npx @insforge/cli secrets add GROQ_API_KEY your_key
